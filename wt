#!/usr/bin/env bash
# wt — git worktrees, one per task, each in its own VS Code window.
#
# Usage:
#   wt <pr-number>          Review/rework a PR: worktree its head branch (number in the name).
#   wt new <branch> [num]   New work: fresh branch off the default branch; optional ticket number.
#   wt <branch-name>        Existing branch by name (local or on origin).
#   wt num <number>         Add a number to the CURRENT worktree (renames + reopens).
#   wt list                 List ALL worktrees under ~/worktrees with repo, PR number and state.
#   wt prune                Remove worktrees whose PR is merged or closed (asks first).
#   wt rm                   Remove the CURRENT worktree (and optionally delete its branch).
#   wt help                 Show this help.
#
# Create/reuse + num + rm run from inside the target repo; list + prune work anywhere.
# Worktrees live in ~/worktrees/<repo>[-<number>]-<sanitized-branch>.

set -euo pipefail

die() { echo "wt: $*" >&2; exit 1; }
sanitize() { echo "$1" | tr '/' '-'; }
usage() { awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "$0"; }

mode=${1:-help}
case "$mode" in help|-h|--help) usage; exit 0 ;; esac
shift || true

# --- colors (only on a terminal) ---
if [ -t 1 ]; then
  C_OPEN=$'\033[32m'; C_MERGED=$'\033[35m'; C_CLOSED=$'\033[31m'
  C_DRAFT=$'\033[90m'; C_DIM=$'\033[2m'; C_RESET=$'\033[0m'; LINKS=1
else
  C_OPEN=""; C_MERGED=""; C_CLOSED=""; C_DRAFT=""; C_DIM=""; C_RESET=""; LINKS=""
fi

# Wrap text $2 in an OSC 8 hyperlink to URL $1 (only on a terminal, only if URL given).
osc8() {
  if [ -n "$LINKS" ] && [ -n "$1" ]; then
    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$1" "$2"
  else
    printf '%s' "$2"
  fi
}
color_for() {
  case "$1" in
    OPEN)   printf '%s' "$C_OPEN" ;;
    MERGED) printf '%s' "$C_MERGED" ;;
    CLOSED) printf '%s' "$C_CLOSED" ;;
    DRAFT)  printf '%s' "$C_DRAFT" ;;
    *)      printf '%s' "$C_DIM" ;;
  esac
}

# Echo "<number> <STATE> <url>" for the PR of branch $2 in worktree dir $1, or nothing.
lookup_pr() {
  command -v gh >/dev/null 2>&1 || return 0
  ( cd "$1" && gh pr list --head "$2" --state all --json number,state,isDraft,url \
      -q 'if length>0 then "\(.[0].number) \(if .[0].isDraft and .[0].state=="OPEN" then "DRAFT" else .[0].state end) \(.[0].url)" else empty end' \
      2>/dev/null ) || true
}

# Repo name that owns worktree dir $1 (basename of its main checkout).
wt_repo() { basename "$(dirname "$(git -C "$1" rev-parse --path-format=absolute --git-common-dir)")"; }

# --- list: every worktree under ~/worktrees, across all repos ---
if [ "$mode" = "list" ] || [ "$mode" = "ls" ]; then
  printf '%-12s %-7s %-7s %-34s %s\n' "REPO" "PR" "STATE" "BRANCH" "PATH"
  shopt -s nullglob
  for d in "$HOME/worktrees"/*/; do
    d=${d%/}
    git -C "$d" rev-parse --git-dir >/dev/null 2>&1 || continue
    wbranch=$(git -C "$d" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "(detached)")
    num=""; state=""; url=""
    read -r num state url <<<"$(lookup_pr "$d" "$wbranch")" || true
    [ -n "$num" ] || { num="-"; state="none"; url=""; }
    prcell=$(osc8 "$url" "$(printf '%-7s' "$num")")
    printf '%-12s %s %s%-7s%s %-34s %s\n' \
      "$(wt_repo "$d")" "$prcell" "$(color_for "$state")" "$state" "$C_RESET" "$wbranch" "$d"
  done
  echo
  echo "${C_DIM}merged/closed PRs can be removed with 'wt prune' or 'wt rm'${C_RESET}"
  exit 0
fi

# --- prune: remove worktrees whose PR is merged or closed (any repo) ---
if [ "$mode" = "prune" ]; then
  paths=(); mains=(); labels=""
  shopt -s nullglob
  for d in "$HOME/worktrees"/*/; do
    d=${d%/}
    git -C "$d" rev-parse --git-dir >/dev/null 2>&1 || continue
    wbranch=$(git -C "$d" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")
    [ -n "$wbranch" ] || continue
    pnum=""; state=""; purl=""
    read -r pnum state purl <<<"$(lookup_pr "$d" "$wbranch")" || true
    if [ "$state" = "MERGED" ] || [ "$state" = "CLOSED" ]; then
      paths+=("$d")
      mains+=("$(dirname "$(git -C "$d" rev-parse --path-format=absolute --git-common-dir)")")
      labels+="  $(color_for "$state")$state$C_RESET  $wbranch  ->  $d"$'\n'
    fi
  done
  if [ "${#paths[@]}" -eq 0 ]; then echo "wt: nothing to prune (no merged/closed-PR worktrees)"; exit 0; fi
  echo "Removable:"; printf '%s' "$labels"
  ans=""; read -r -p "Remove these ${#paths[@]} worktree(s)? [y/N] " ans || ans=""
  case "$ans" in [yY]*) ;; *) echo "aborted"; exit 0 ;; esac
  i=0
  for p in "${paths[@]}"; do
    m=${mains[$i]}; i=$((i+1))
    if git -C "$m" worktree remove "$p" 2>/dev/null; then
      echo "removed $p"
    else
      echo "skipped $p (uncommitted changes — remove with: git -C '$m' worktree remove --force '$p')"
    fi
  done
  exit 0
fi

# ===== everything below needs to run inside the target repo =====
git rev-parse --git-dir >/dev/null 2>&1 || die "run this inside the target git repository"
common=$(git rev-parse --path-format=absolute --git-common-dir)
main_root=$(dirname "$common")
repo=$(basename "$main_root")
default=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@' || true)
[ -n "$default" ] || default=main

# --- rm: remove the current worktree ---
if [ "$mode" = "rm" ]; then
  cur=$(git rev-parse --show-toplevel)
  [ "$cur" != "$main_root" ] || die "run this from inside the worktree to remove, not the main checkout"
  branch=$(git -C "$cur" symbolic-ref --quiet --short HEAD || true)
  git -C "$main_root" worktree remove "$cur" 2>/dev/null \
    || die "worktree has uncommitted changes — commit/stash, or force: git worktree remove --force '$cur'"
  echo "wt: removed $cur"
  if [ -n "$branch" ]; then
    ans=""; read -r -p "Also delete branch '$branch'? [y/N] " ans || ans=""
    case "$ans" in
      [yY]*)
        if git -C "$main_root" branch -d "$branch" 2>/dev/null; then
          echo "deleted branch $branch"
        else
          echo "branch '$branch' not fully merged; force with: git -C '$main_root' branch -D '$branch'"
        fi ;;
    esac
  fi
  echo "(close this window — its directory is gone)"
  exit 0
fi

# --- num: add a number to the current worktree ---
if [ "$mode" = "num" ]; then
  [ $# -ge 1 ] || die "usage: wt num <number>"
  num=$1
  cur=$(git rev-parse --show-toplevel)
  [ "$cur" != "$main_root" ] || die "run this from inside a worktree, not the main checkout"
  branch=$(git -C "$cur" symbolic-ref --quiet --short HEAD) || die "worktree is not on a branch"
  newpath="$HOME/worktrees/${repo}-${num}-$(sanitize "$branch")"
  [ "$cur" != "$newpath" ] || die "already named that"
  git -C "$main_root" worktree move "$cur" "$newpath"
  code "$newpath"
  echo "wt: moved to $newpath  (you can close the old window)"
  exit 0
fi

# --- create/reuse: determine branch (+ optional number) ---
num=""
if [ "$mode" = "new" ]; then
  [ $# -ge 1 ] || die "usage: wt new <branch> [num]"
  branch=$1
  num=${2:-}
  git -C "$main_root" fetch --quiet origin "$default"
  base_ref="origin/$default"
  new_branch=1
elif [[ "$mode" =~ ^[0-9]+$ ]]; then
  command -v gh >/dev/null 2>&1 || die "gh not found (needed to resolve PR #$mode)"
  num=$mode
  branch=$( (cd "$main_root" && gh pr view "$mode" --json headRefName -q .headRefName) 2>/dev/null ) \
    || die "could not resolve PR #$mode in $repo"
  # pull/N/head works for fork PRs too; fall back to a plain branch fetch.
  git -C "$main_root" fetch --quiet origin "pull/$mode/head:$branch" 2>/dev/null \
    || git -C "$main_root" fetch --quiet origin "$branch:$branch" 2>/dev/null || true
  new_branch=0
else
  branch=$mode
  git -C "$main_root" fetch --quiet origin "$branch:$branch" 2>/dev/null || true
  new_branch=0
fi

slug=$(sanitize "$branch")
[ -n "$num" ] && slug="${num}-${slug}"
wtpath="$HOME/worktrees/${repo}-${slug}"
mkdir -p "$HOME/worktrees"

if git -C "$main_root" worktree list --porcelain | grep -qx "worktree $wtpath"; then
  echo "wt: reusing existing worktree"
elif [ "${new_branch}" = "1" ]; then
  git -C "$main_root" worktree add "$wtpath" -b "$branch" "$base_ref"
elif git -C "$main_root" show-ref --verify --quiet "refs/heads/$branch"; then
  git -C "$main_root" worktree add "$wtpath" "$branch"
else
  git -C "$main_root" worktree add "$wtpath" -b "$branch" "origin/$branch"
fi

code "$wtpath"
echo "wt: $wtpath  (branch: $branch)"
