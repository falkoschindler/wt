#!/usr/bin/env bash
# wt — git worktrees, one per task, each in its own VS Code window.
#
# Usage:
#   wt <pr-number>          Review/rework a PR: worktree its head branch (number in the name).
#                           Outside a repo: open the existing worktree with that number (if unique).
#   wt new <branch> [num]   New work: fresh branch off the default branch; optional ticket number.
#   wt <branch-name>        Existing branch by name (local or on origin).
#   wt num <number>         Add a number to the CURRENT worktree (renames + reopens).
#   wt list                 List ALL worktrees under ~/worktrees with repo, PR number, state and milestone.
#   wt board                Maintainer queue: open issues + PRs in THIS repo grouped by assignee.
#   wt prune                Remove worktrees whose PR is merged or closed (asks first).
#   wt rm                   Remove the CURRENT worktree (and optionally delete its branch).
#   wt help                 Show this help.
#
# Create/reuse + num + rm + board run from inside the target repo; list + prune work anywhere.
# Outside a repo, a bare number opens a matching existing worktree if there's exactly one.
# Worktrees live in ~/worktrees/<repo>[-<number>]-<sanitized-branch>.

set -euo pipefail

die() { echo "wt: $*" >&2; exit 1; }
sanitize() { echo "$1" | tr '/' '-'; }
usage() { awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "$0"; }

# Open a worktree in VS Code. Set WT_NO_OPEN=1 to skip opening (e.g. when an agent/skill
# drives wt and enters the worktree in the terminal, not a new window). When WT_NO_OPEN is
# unset the call is byte-identical to the previous `code "$1"` — default behavior unchanged.
open_editor() {
  if [ "${WT_NO_OPEN:-0}" = "1" ]; then
    echo "wt: WT_NO_OPEN set — not opening editor ($1)"
  else
    code "$1"
  fi
}

mode=${1:-help}
case "$mode" in help|-h|--help) usage; exit 0 ;; esac
shift || true

# --- colors (only on a terminal) ---
if [ -t 1 ]; then
  C_OPEN=$'\033[32m'; C_MERGED=$'\033[35m'; C_CLOSED=$'\033[31m'
  C_DRAFT=$'\033[90m'; C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'; C_RESET=$'\033[0m'; LINKS=1
else
  C_OPEN=""; C_MERGED=""; C_CLOSED=""; C_DRAFT=""; C_DIM=""; C_BOLD=""; C_RESET=""; LINKS=""
fi

# Wrap text $2 in an OSC 8 hyperlink to URL $1 (only on a terminal, only if URL given).
osc8() {
  if [ -n "$LINKS" ] && [ -n "$1" ]; then
    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$1" "$2"
  else
    printf '%s' "$2"
  fi
}

# Left-justify text $2 (linked to URL $1) in a field of width $3, padding OUTSIDE the
# link so only the text — not the trailing spaces — is underlined.
cell() {
  local pad=$(( $3 - ${#2} )); [ "$pad" -lt 0 ] && pad=0
  osc8 "$1" "$2"; printf '%*s' "$pad" ""
}
color_for() {
  case "$1" in
    OPEN)   printf '%s' "$C_OPEN" ;;
    MERGED) printf '%s' "$C_MERGED" ;;
    CLOSED) printf '%s' "$C_CLOSED" ;;
    DRAFT)  printf '%s' "$C_DRAFT" ;;
    *)      printf '%s' "$C_DIM" ;;
  esac
}

# Echo "<number> <STATE> <url> <milestone-number> <milestone-title>" for the PR of branch $2
# in worktree dir $1, or nothing. The milestone title comes last because it may contain spaces.
lookup_pr() {
  command -v gh >/dev/null 2>&1 || return 0
  ( cd "$1" && gh pr list --head "$2" --state all --json number,state,isDraft,url,milestone \
      -q 'if length>0 then "\(.[0].number) \(if .[0].isDraft and .[0].state=="OPEN" then "DRAFT" else .[0].state end) \(.[0].url) \(.[0].milestone.number // "-") \(.[0].milestone.title // "-")" else empty end' \
      2>/dev/null ) || true
}

# Repo name that owns worktree dir $1 (basename of its main checkout).
wt_repo() { basename "$(dirname "$(git -C "$1" rev-parse --path-format=absolute --git-common-dir)")"; }

# https base URL of the GitHub repo that owns worktree dir $1, or nothing (non-GitHub origins).
repo_url() {
  local u
  u=$(git -C "$1" remote get-url origin 2>/dev/null) || return 0
  case "$u" in
    git@github.com:*)       u="https://github.com/${u#git@github.com:}" ;;
    ssh://git@github.com/*) u="https://github.com/${u#ssh://git@github.com/}" ;;
    https://github.com/*)   : ;;
    *) return 0 ;;
  esac
  printf '%s' "${u%.git}"
}

# Run lookup_pr for many worktrees concurrently. Reads parallel arrays `dirs` and
# `branches`, writes each PR line to "$1/<index>" so callers read results back in order.
# One network round-trip total instead of one per worktree.
parallel_lookups() {
  local i
  for i in "${!dirs[@]}"; do
    lookup_pr "${dirs[$i]}" "${branches[$i]}" >"$1/$i" &
  done
  wait
}

# --- list: every worktree under ~/worktrees, across all repos ---
if [ "$mode" = "list" ] || [ "$mode" = "ls" ]; then
  printf '%-12s %-7s %-7s %-12s %-34s %s\n' "REPO" "PR" "STATE" "MILESTONE" "BRANCH" "PATH"
  shopt -s nullglob
  dirs=(); branches=()
  for d in "$HOME/worktrees"/*/; do
    d=${d%/}
    git -C "$d" rev-parse --git-dir >/dev/null 2>&1 || continue
    dirs+=("$d")
    branches+=("$(git -C "$d" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "(detached)")")
  done
  tmp=$(mktemp -d); trap 'rm -rf "$tmp"' EXIT
  parallel_lookups "$tmp"
  for i in "${!dirs[@]}"; do
    d=${dirs[$i]}; wbranch=${branches[$i]}
    num=""; state=""; url=""; milenum=""; mile=""
    read -r num state url milenum mile <"$tmp/$i" || true
    [ -n "$num" ] || { num="-"; state="none"; url=""; milenum="-"; mile="-"; }
    repourl=$(repo_url "$d"); mileurl=""
    # Note: no branch link — the head branch may live on a fork or be unpushed, so a
    # /tree/<branch> URL on origin would 404. Repo/PR/milestone resolve reliably.
    [ -n "$repourl" ] && [[ "$milenum" =~ ^[0-9]+$ ]] && mileurl="$repourl/milestone/$milenum"
    repocell=$(cell "$repourl" "$(wt_repo "$d")" 12)
    prcell=$(cell "$url" "$num" 7)
    milecell=$(cell "$mileurl" "$mile" 12)
    branchcell=$(cell "" "$wbranch" 34)
    pathcell=$(osc8 "vscode://file$d" "$d")
    printf '%s %s %s%-7s%s %s %s %s\n' \
      "$repocell" "$prcell" "$(color_for "$state")" "$state" "$C_RESET" "$milecell" "$branchcell" "$pathcell"
  done
  echo
  echo "${C_DIM}merged/closed PRs can be removed with 'wt prune' or 'wt rm'${C_RESET}"
  exit 0
fi

# --- prune: remove worktrees whose PR is merged or closed (any repo) ---
if [ "$mode" = "prune" ]; then
  paths=(); mains=(); labels=""
  shopt -s nullglob
  dirs=(); branches=()
  for d in "$HOME/worktrees"/*/; do
    d=${d%/}
    git -C "$d" rev-parse --git-dir >/dev/null 2>&1 || continue
    wbranch=$(git -C "$d" symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")
    [ -n "$wbranch" ] || continue
    dirs+=("$d"); branches+=("$wbranch")
  done
  tmp=$(mktemp -d); trap 'rm -rf "$tmp"' EXIT
  parallel_lookups "$tmp"
  for i in "${!dirs[@]}"; do
    d=${dirs[$i]}; wbranch=${branches[$i]}
    pnum=""; state=""; purl=""
    read -r pnum state purl <"$tmp/$i" || true
    if [ "$state" = "MERGED" ] || [ "$state" = "CLOSED" ]; then
      paths+=("$d")
      mains+=("$(dirname "$(git -C "$d" rev-parse --path-format=absolute --git-common-dir)")")
      labels+="  $(color_for "$state")$state$C_RESET  $wbranch  ->  $d"$'\n'
    fi
  done
  if [ "${#paths[@]}" -eq 0 ]; then echo "wt: nothing to prune (no merged/closed-PR worktrees)"; exit 0; fi
  echo "Removable:"; printf '%s' "$labels"
  ans=""; read -r -p "Remove these ${#paths[@]} worktree(s)? [y/N] " ans || ans=""
  case "$ans" in [yY]*) ;; *) echo "aborted"; exit 0 ;; esac
  i=0
  for p in "${paths[@]}"; do
    m=${mains[$i]}; i=$((i+1))
    if git -C "$m" worktree remove "$p" 2>/dev/null; then
      echo "removed $p"
    else
      echo "skipped $p (uncommitted changes — remove with: git -C '$m' worktree remove --force '$p')"
    fi
  done
  exit 0
fi

# --- outside a repo: a bare number opens the existing worktree with that number ---
# Worktrees are named <repo>-<number>-<branch>, so the number is the segment right
# after the repo. If exactly one worktree matches, open it; if several, ask to narrow.
if [[ "$mode" =~ ^[0-9]+$ ]] && ! git rev-parse --git-dir >/dev/null 2>&1; then
  num=$mode
  matches=()
  shopt -s nullglob
  for d in "$HOME/worktrees"/*/; do
    d=${d%/}
    git -C "$d" rev-parse --git-dir >/dev/null 2>&1 || continue
    [[ "$(basename "$d")" == "$(wt_repo "$d")-${num}-"* ]] && matches+=("$d")
  done
  case "${#matches[@]}" in
    0) die "no worktree numbered $num under ~/worktrees (run inside a repo to create one)" ;;
    1) open_editor "${matches[0]}"; echo "wt: ${matches[0]}"; exit 0 ;;
    *) echo "wt: multiple worktrees numbered $num:" >&2
       printf '  %s\n' "${matches[@]}" >&2
       die "narrow it down, or run inside the target repo" ;;
  esac
fi

# ===== everything below needs to run inside the target repo =====
git rev-parse --git-dir >/dev/null 2>&1 || die "run this inside the target git repository"
common=$(git rev-parse --path-format=absolute --git-common-dir)
main_root=$(dirname "$common")
repo=$(basename "$main_root")
default=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@' || true)
[ -n "$default" ] || default=main

# --- board: open issues + PRs grouped by assignee (the "maintainer queue") ---
# A live, zero-upkeep view of who owns what: every open issue/PR with an assignee in THIS
# repo, grouped by assignee and ordered by milestone (earliest due date first, undated
# milestones then no-milestone last). A ✓ marks items you already have as a local worktree.
# Read-only — nothing is fetched or changed. Your own group floats to the top.
if [ "$mode" = "board" ]; then
  command -v gh >/dev/null 2>&1 || die "gh not found (needed for 'wt board')"
  tmp=$(mktemp -d); trap 'rm -rf "$tmp"' EXIT

  # One TSV row per (assignee, item): login, due, milestone, kind, number, url, branch,
  # draft, name, title. Undated milestones get a "9999" sentinel so they sort after dated
  # ones; "-" marks no milestone. assignees[]? expands to one row per assignee (none → skip).
  # branch is "-" when absent (issues, headless PRs): an empty field would be swallowed by
  # read's tab-IFS whitespace-collapse and shift every later column. No-milestone is "-" too,
  # ASCII so the column aligns (a multibyte "—" pads by bytes, not display width).
  iss_jq='.[] | . as $i | ($i.assignees[]?) as $a | [$a.login, ($i.milestone.dueOn // "9999"), ($i.milestone.title // "-"), "issue", ($i.number|tostring), $i.url, "-", "false", ($a.name // $a.login), $i.title] | @tsv'
  pr_jq='.[]  | . as $i | ($i.assignees[]?) as $a | [$a.login, ($i.milestone.dueOn // "9999"), ($i.milestone.title // "-"), "pr",    ($i.number|tostring), $i.url, ($i.headRefName // "-"), ($i.isDraft|tostring), ($a.name // $a.login), $i.title] | @tsv'

  # Login + issues + PRs fetched concurrently — the network is the only slow part.
  ( gh api user --jq .login >"$tmp/me" 2>/dev/null ) &
  ( cd "$main_root" && gh issue list --state open --limit 500 \
      --json number,title,url,assignees,milestone --jq "$iss_jq" >"$tmp/iss" 2>/dev/null ) &
  ( cd "$main_root" && gh pr list --state open --limit 500 \
      --json number,title,url,assignees,milestone,headRefName,isDraft --jq "$pr_jq" >"$tmp/pr" 2>/dev/null ) &
  wait
  cat "$tmp/iss" "$tmp/pr" 2>/dev/null | sort -t"$(printf '\t')" -k2,2 -k3,3 -k5,5n >"$tmp/rows"
  [ -s "$tmp/rows" ] || { echo "wt: nothing assigned in $repo"; exit 0; }

  # Branches that currently have a worktree in this repo (for the ✓ column).
  wtset="|"
  while IFS= read -r line; do
    case "$line" in "branch refs/heads/"*) wtset="${wtset}${line#branch refs/heads/}|" ;; esac
  done < <(git -C "$main_root" worktree list --porcelain 2>/dev/null)

  me=$(cat "$tmp/me" 2>/dev/null || true)
  cols=80; [ -t 1 ] && cols=$( { tput cols; } 2>/dev/null || echo 80 )
  total=$(cut -f5 "$tmp/rows" | sort -u | grep -c '')  # unique items (an item with 2 assignees lists twice)
  printf '%s%s%s  %s%s open assigned · ✓ = worktree exists%s\n' \
    "$C_BOLD" "$repo" "$C_RESET" "$C_DIM" "$total" "$C_RESET"

  # Group order: the current user first, then everyone else case-insensitively.
  order=""
  [ -n "$me" ] && cut -f1 "$tmp/rows" | grep -Fqx "$me" && order="$me"$'\n'
  if [ -n "$me" ]; then
    order+=$(cut -f1 "$tmp/rows" | sort -fu | grep -Fvx "$me" || true)
  else
    order+=$(cut -f1 "$tmp/rows" | sort -fu)
  fi

  printf '%s\n' "$order" | while IFS= read -r login; do
    [ -n "$login" ] || continue
    count=$(awk -F"$(printf '\t')" -v u="$login" '$1==u' "$tmp/rows" | grep -c '')
    name=$(awk -F"$(printf '\t')" -v u="$login" '$1==u{print $9; exit}' "$tmp/rows")
    [ -n "$name" ] || name=$login
    printf '\n%s%s%s %s@%s (%s)%s\n' "$C_BOLD" "$name" "$C_RESET" "$C_DIM" "$login" "$count" "$C_RESET"
    while IFS="$(printf '\t')" read -r l due mile kind num url branch draft nm title; do
      if [ "$kind" = pr ] && [ "$branch" != "-" ] && [[ "$wtset" == *"|$branch|"* ]]; then
        mark="${C_OPEN}✓${C_RESET}"
      else
        mark=" "
      fi
      if [ "$draft" = true ]; then kc=$C_DRAFT; kd="draft"
      elif [ "$kind" = pr ];  then kc=$C_OPEN;  kd="PR"
      else                         kc=$C_DIM;   kd="issue"; fi
      avail=$(( cols - 29 )); [ "$avail" -lt 20 ] && avail=20
      t=$title; [ "${#t}" -gt "$avail" ] && t="${t:0:avail-1}…"
      printf '  %s %s%-8s%s %s%-6s%s %s  %s\n' \
        "$mark" "$C_DIM" "$mile" "$C_RESET" "$kc" "$kd" "$C_RESET" \
        "$(cell "$url" "#$num" 6)" "$(osc8 "$url" "$t")"
    done < <(awk -F"$(printf '\t')" -v u="$login" '$1==u' "$tmp/rows")
  done
  echo
  exit 0
fi

# --- rm: remove the current worktree ---
if [ "$mode" = "rm" ]; then
  cur=$(git rev-parse --show-toplevel)
  [ "$cur" != "$main_root" ] || die "run this from inside the worktree to remove, not the main checkout"
  branch=$(git -C "$cur" symbolic-ref --quiet --short HEAD || true)
  git -C "$main_root" worktree remove "$cur" 2>/dev/null \
    || die "worktree has uncommitted changes — commit/stash, or force: git worktree remove --force '$cur'"
  echo "wt: removed $cur"
  if [ -n "$branch" ]; then
    ans=""; read -r -p "Also delete branch '$branch'? [y/N] " ans || ans=""
    case "$ans" in
      [yY]*)
        if git -C "$main_root" branch -d "$branch" 2>/dev/null; then
          echo "deleted branch $branch"
        else
          echo "branch '$branch' not fully merged; force with: git -C '$main_root' branch -D '$branch'"
        fi ;;
    esac
  fi
  echo "(close this window — its directory is gone)"
  exit 0
fi

# --- num: add a number to the current worktree ---
if [ "$mode" = "num" ]; then
  [ $# -ge 1 ] || die "usage: wt num <number>"
  num=$1
  cur=$(git rev-parse --show-toplevel)
  [ "$cur" != "$main_root" ] || die "run this from inside a worktree, not the main checkout"
  branch=$(git -C "$cur" symbolic-ref --quiet --short HEAD) || die "worktree is not on a branch"
  newpath="$HOME/worktrees/${repo}-${num}-$(sanitize "$branch")"
  [ "$cur" != "$newpath" ] || die "already named that"
  git -C "$main_root" worktree move "$cur" "$newpath"
  open_editor "$newpath"
  echo "wt: moved to $newpath  (you can close the old window)"
  exit 0
fi

# --- create/reuse: determine branch (+ optional number) ---
num=""
if [ "$mode" = "new" ]; then
  [ $# -ge 1 ] || die "usage: wt new <branch> [num]"
  branch=$1
  num=${2:-}
  git -C "$main_root" fetch --quiet origin "$default"
  base_ref="origin/$default"
  new_branch=1
elif [[ "$mode" =~ ^[0-9]+$ ]]; then
  command -v gh >/dev/null 2>&1 || die "gh not found (needed to resolve PR #$mode)"
  num=$mode
  branch=$( (cd "$main_root" && gh pr view "$mode" --json headRefName -q .headRefName) 2>/dev/null ) \
    || die "could not resolve PR #$mode in $repo"
  # pull/N/head works for fork PRs too; fall back to a plain branch fetch.
  git -C "$main_root" fetch --quiet origin "pull/$mode/head:$branch" 2>/dev/null \
    || git -C "$main_root" fetch --quiet origin "$branch:$branch" 2>/dev/null || true
  new_branch=0
else
  branch=$mode
  git -C "$main_root" fetch --quiet origin "$branch:$branch" 2>/dev/null || true
  new_branch=0
fi

slug=$(sanitize "$branch")
[ -n "$num" ] && slug="${num}-${slug}"
wtpath="$HOME/worktrees/${repo}-${slug}"
mkdir -p "$HOME/worktrees"

if git -C "$main_root" worktree list --porcelain | grep -qx "worktree $wtpath"; then
  echo "wt: reusing existing worktree"
elif [ "${new_branch}" = "1" ]; then
  git -C "$main_root" worktree add "$wtpath" -b "$branch" "$base_ref"
elif git -C "$main_root" show-ref --verify --quiet "refs/heads/$branch"; then
  git -C "$main_root" worktree add "$wtpath" "$branch"
else
  git -C "$main_root" worktree add "$wtpath" -b "$branch" "origin/$branch"
fi

# Make `git pull` work without arguments. wt fetches branches with an explicit refspec
# (or via pull/N/head), which creates the local branch but leaves no upstream and no
# origin/<branch> remote-tracking ref. Fetch the branch the normal way (this updates
# origin/<branch> through origin's configured refspec) and point the worktree branch at
# it. Branches not on origin (e.g. fork-PR heads, brand-new `wt new` branches) make the
# fetch fail, so they're left untouched.
if git -C "$wtpath" fetch --quiet origin "$branch" 2>/dev/null; then
  git -C "$wtpath" branch --quiet --set-upstream-to="origin/$branch" "$branch" 2>/dev/null || true
fi

open_editor "$wtpath"
echo "wt: $wtpath  (branch: $branch)"
